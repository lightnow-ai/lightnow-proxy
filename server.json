{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.lightnow-ai/lightnow-proxy",
  "title": "LightNow Secure MCP Gateway",
  "description": "Securely connect AI clients to your team's approved MCP servers—no copied configs or secrets.",
  "icons": [
    {
      "src": "https://docs.lightnow.ai/favicon-192x192.png",
      "mimeType": "image/png",
      "sizes": [
        "192x192"
      ]
    },
    {
      "src": "https://docs.lightnow.ai/favicon-512x512.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/lightnow-ai/lightnow-proxy",
    "source": "github",
    "id": "1291018077"
  },
  "websiteUrl": "https://docs.lightnow.ai/getting-started/sync-mcp-clients/",
  "version": "1.6.0",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "lightnow-proxy",
      "version": "1.6.0",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "named",
          "name": "--config",
          "description": "Run `lightnow sync --client <client> --local-proxy` first, then select the generated proxy YAML for this client.",
          "format": "filepath",
          "placeholder": "~/.lightnow/lightnow-proxy/default.yaml",
          "isRequired": true
        },
        {
          "type": "named",
          "name": "--transport",
          "value": "stdio"
        }
      ]
    }
  ]
}
